# =============================================================================
# Love AIsland environment reference.
#
# Copy to .env only if you want persistent local overrides. Nothing here is
# required: every variable has a working default, and the sim boots with an
# entirely empty environment.
#
# Every name below is read somewhere in the tree. The two config surfaces are:
#   packages/shared/src/tunables.ts   ISLAND_*   game behavior
#   packages/swarm/src/config.ts      SWARM_*    which model answers a think
# The rest are read directly by apps/server.
# =============================================================================


# -----------------------------------------------------------------------------
# READ THIS FIRST: two settings that silently do nothing on their own.
# -----------------------------------------------------------------------------
#
# 1. ANTHROPIC_API_KEY ALONE CHANGES NOTHING.
#    The backend factory only reads the key when the active backend is the
#    Anthropic one. Set SWARM_BACKEND=anthropic as well, or the key sits unused
#    and the sim runs on whatever the default backend resolves to.
#
# 2. THE LOCAL MODEL MUST ACTUALLY BE PULLED.
#    The local path targets SWARM_LOCAL_MODEL. If that model is not installed in
#    Ollama, every call 404s, the circuit breaker opens after a few failures, and
#    the rest of the run is rule-engine templates with no visible error. That is
#    indistinguishable from "the writing is bad" unless you check the boot log.
#    Confirm with `ollama list` before blaming the dialogue.


# =============================================================================
# BEHAVIOR FLAGS
# =============================================================================
#
# ISLAND_BEHAVIOR_ALL is the master switch and DEFAULTS TO 1. The shipped game
# is the lively one. Every individual flag below overrides it in BOTH
# directions, so both of these work:
#
#   ISLAND_BEHAVIOR_ALL=0                          the exact pre-spec build
#   ISLAND_BEHAVIOR_ALL=0 ISLAND_STRIP_DASHES=1    pre-spec plus one feature
#   ISLAND_OVERHEARING=0                           everything except one feature
#
# Accepted false values: 0, false, off (case insensitive). Anything else is true.

ISLAND_BEHAVIOR_ALL=1

# --- the seventeen original behavior flags -----------------------------------
ISLAND_CONVERSATION_VARIETY=1   # ordinary topics, not only game talk
ISLAND_STRIP_DASHES=1           # no dashes of any kind in islander speech
ISLAND_VOTE_REASONING=1         # votes cite threat, likability and vote math
ISLAND_VOTE_DEFLECTION=1        # a threatened target steers votes elsewhere
ISLAND_EARLY_AGGRESSION=1       # raised early-game conflict baseline, ramped in
ISLAND_SELF_ODDS=1              # coarse private sense of own standing, never a number
ISLAND_MULTI_ALLIANCES=1        # alliances of three or more, tracked as groups
ISLAND_ALLIANCE_DEFECTION=1     # cohesion decay and members walking out
ISLAND_SPONTANEOUS_OUSTER=1     # agent-driven elimination push between events
ISLAND_VOTE_RESOLUTION=1        # plurality plus the one tie rule (health, then seed)
ISLAND_WORLD_AWARENESS=1        # event feed and world state reach the agent
ISLAND_SPATIAL_AWARENESS=1      # compute crowded vs secluded
ISLAND_OVERHEARING=1            # capture fragments of nearby conversations
ISLAND_MARKET_EVENT_DRIFT=1     # odds move on observable events, not only bets
ISLAND_RELATIONSHIP_MEMORY=1    # per-pair trust, threat and affinity
ISLAND_OUTCOME_ICONS=1          # tension and amicable icons on the island
ISLAND_CALM_CONVERSATIONS=1     # islanders move much less while talking

# --- flags added alongside the follow camera and rich SMS work ---------------
ISLAND_FOLLOW_CAMERA=1          # camera can follow an islander or a portfolio
ISLAND_RICH_NOTIFICATIONS=1     # event-aware SMS about your islander and your bets
ISLAND_GOSSIP=1                 # overheard fragments reach speech and decisions
ISLAND_SPATIAL_BEHAVIOR=1       # crowded vs secluded actually changes what agents do
ISLAND_CALL_BUDGET=1            # cap model calls per tick, degrade to rules
ISLAND_CONVERSATION_HISTORY=1   # client retains ended transcripts so you can swipe back

# --- flag dependencies -------------------------------------------------------
#
# These flags are independent env reads, so a degenerate combination is
# reachable. With the master switch on none of it bites; it bites when you
# disable one flag to isolate a behavior.
#
#   ISLAND_VOTE_DEFLECTION      needs ISLAND_WORLD_AWARENESS, or it yields nothing.
#   ISLAND_SELF_ODDS            degrades without ISLAND_RELATIONSHIP_MEMORY.
#   ISLAND_MULTI_ALLIANCES      needs ISLAND_RELATIONSHIP_MEMORY, or cohesion pins
#                               at its fixed point and blocs can never crack.
#   ISLAND_OUTCOME_ICONS        needs ISLAND_RELATIONSHIP_MEMORY for more than two
#                               of its four glyphs.
#   ISLAND_EARLY_AGGRESSION     needs ISLAND_WORLD_AWARENESS for a smooth ramp.
#   ISLAND_GOSSIP               needs ISLAND_OVERHEARING (capture vs passing on).
#   ISLAND_SPATIAL_BEHAVIOR     needs ISLAND_SPATIAL_AWARENESS (signal vs reaction).


# =============================================================================
# BEHAVIOR TUNABLES
# =============================================================================
# All optional. Shown with their defaults. Every one of these is read in
# packages/shared/src/tunables.ts.

# --- conflict ----------------------------------------------------------------
ISLAND_CONFLICT_WARMUP_MS=120000        # conflict ramps in over this window
ISLAND_BASE_CONFLICT_CHANCE=0.14        # per eligible conversation, after warmup
ISLAND_BASE_VOTE_PUSH_CHANCE=0.1        # per think, after warmup
ISLAND_PAIR_CONFLICT_COOLDOWN_MS=90000  # a pair that just fought will not immediately refight

# Per-class multipliers. Each of these is a PREFIX: the real variables are
# <PREFIX>_BOLD, _TIMID, _SCHEMER, _CHARMER, _WILDCARD.
# e.g. ISLAND_CONFLICT_MUL_BOLD=1.6
# ISLAND_CONFLICT_MUL_*     defaults bold 1.6, timid 0.35, schemer 1.15, charmer 0.7, wildcard 1.2
# ISLAND_VOTE_PUSH_MUL_*    defaults bold 1.3, timid 0.4, schemer 1.7, charmer 0.9, wildcard 1.0
# ISLAND_SELF_ODDS_SENS_*   defaults bold 0.6, timid 1.5, schemer 1.3, charmer 0.9, wildcard 0.7
# ISLAND_CROWDED_MUL_*      defaults bold 1.45, timid 0.55, schemer 0.75, charmer 1.25, wildcard 1.15
# ISLAND_SECLUDED_MUL_*     defaults bold 0.8, timid 1.15, schemer 1.55, charmer 0.85, wildcard 1.0

# --- social and alliances ----------------------------------------------------
ISLAND_OUSTER_THRESHOLD=0.3333333333333333  # fraction of the living needed to push an ouster
ISLAND_MAX_ALLIANCE_SIZE=5
ISLAND_COHESION_START=0.5
ISLAND_COHESION_GAIN=0.12                   # per shared good outcome
ISLAND_COHESION_LOSS=0.4                    # per betrayal
ISLAND_COHESION_GAIN_JOINT_VOTE=0.2         # per bloc that converged on an eliminated target
ISLAND_DEFECTION_FLOOR=0.2                  # below this a member may walk
ISLAND_VOTE_ELIMINATION_COUNT=0             # 0 keeps today's purge-equivalent slice; 1 matches the spec's singular wording
ISLAND_COHESION_SCAN_MS=5000                # how often cohesion drift is re-evaluated
ISLAND_OUSTER_SUPPORT_TTL_MS=120000         # a supporter older than this stops counting

# --- awareness ---------------------------------------------------------------
ISLAND_OVERHEAR_RADIUS=96       # px, close enough to pick up part of a conversation
ISLAND_DENSITY_RADIUS=160       # px, the neighborhood density is measured over
ISLAND_CROWDED_COUNT=4          # neighbors at or above this reads as crowded
ISLAND_SECLUDED_COUNT=1         # neighbors at or below this reads as secluded
ISLAND_OVERHEARD_CAP=5          # fragments retained per listener
ISLAND_OVERHEARD_DECAY_MS=180000 # a fragment older than this is not worth passing on

# --- relationship memory -----------------------------------------------------
ISLAND_REL_HISTORY=12           # outcomes retained per ordered pair
ISLAND_REL_HALF_LIFE_MS=300000  # an outcome's weight halves over this span, never erased
ISLAND_TRUST_ALLIANCE=0.35
ISLAND_TRUST_AMICABLE=0.15
ISLAND_TRUST_TENSION=-0.18
ISLAND_TRUST_FIGHT=-0.45
ISLAND_THREAT_FIGHT=0.3
ISLAND_THREAT_KILL=0.5
ISLAND_AFFINITY_AMICABLE=0.25
ISLAND_AFFINITY_TENSION=-0.25

# --- market ------------------------------------------------------------------
# Death is deliberately absent from the drift table. The board shows a
# normalized chance to win, so a death shrinks the denominator and every
# survivor's displayed percentage rises on its own. Nudging raw shares on death
# too would count the same thing twice.
ISLAND_DRIFT_ALLIANCE=0.015
ISLAND_DRIFT_FIGHT=-0.02
ISLAND_DRIFT_TENSION=-0.01
ISLAND_DRIFT_AMICABLE=0.008
ISLAND_DRIFT_PURGE=0.02
ISLAND_MAX_DRIFT=0.05           # no single event moves a price more than this
ISLAND_PRICE_FLOOR=0.02
ISLAND_PRICE_CEIL=0.98
ISLAND_PER_TRADE_CAP=25         # tokens per bet, keeps a whale off the tails
ISLAND_PRICE_HEARTBEAT_MS=5000

# --- notifications -----------------------------------------------------------
ISLAND_NOTIFY_COOLDOWN_MS=60000          # legacy global per-spectator window
ISLAND_NOTIFY_SURGE_DELTA=0.08           # points up from the tracked low that earns a text
ISLAND_NOTIFY_DROP_DELTA=0.08            # points down from the tracked high
ISLAND_NOTIFY_CATEGORY_COOLDOWN_MS=60000 # window for a category with no explicit entry
# Per-category windows, as a comma-separated name:ms list merged onto the
# defaults. A malformed entry is ignored rather than fatal.
# Defaults: payout 0, death 0, purge 0, voteResult 30000, fight 45000,
#           allianceBroken 60000, allianceFormed 90000, ousterSupport 120000,
#           drop 120000, surge 120000, tension 150000, amicable 180000.
# ISLAND_NOTIFY_CATEGORY_COOLDOWNS=surge:300000,amicable:600000

# --- swarm behavior ----------------------------------------------------------
ISLAND_CALL_BUDGET_PER_TICK=24  # model calls admitted per tick, then degrade to rules
ISLAND_RAMP_EARLY_CAP=0.45      # aggression ceiling in the opening phase
ISLAND_RAMP_MID=0.7
ISLAND_RAMP_LATE=0.9
ISLAND_VOTE_W_THREAT=0.55       # how a vote target is scored
ISLAND_VOTE_W_LIKABILITY=0.3
ISLAND_VOTE_W_GRIEVANCE=0.15    # smallest on purpose: Survivor reasoning, not raw dislike
ISLAND_AMICABLE_CHANCE=0.35
ISLAND_RECENTLY_SAID_WINDOW=24  # per-agent ring of recently spoken lines, excluded from selection
ISLAND_BREAKER_FAILURES=3       # consecutive backend failures before the primary is skipped
ISLAND_BREAKER_COOLDOWN_MS=30000

# --- movement and reproducibility --------------------------------------------
ISLAND_IDLE_PACE=1
ISLAND_TALKING_PACE=0.18        # much less, not frozen
ISLAND_RUN_SEED=0               # 0 means pick one at start and report it in the boot log


# =============================================================================
# MODEL BACKEND
# =============================================================================
# Read in packages/swarm/src/config.ts. Whatever the active backend, the rule
# engine is wired underneath it as an automatic fallback, so the sim keeps
# running with no model reachable at all.

# Master switch for the whole backend seam. 0 restores the pre-seam wiring.
SWARM_BACKEND_ENABLED=1

# Active backend: local | anthropic | rules. Unset currently resolves to local.
# The intended end state is an order of preference (Anthropic if a key is set,
# else a reachable local model, else rules), and an explicit value always wins
# over that selection.
# SWARM_BACKEND=local

# Local (Ollama). Free per call, so the swarm can make as many calls as the
# hardware allows and rate limits do not apply.
SWARM_LOCAL_HOST=http://127.0.0.1:11434
# The model to target. The current default is llama3.2, which must actually be
# pulled (`ollama pull llama3.2`) or every line silently degrades to templates.
# If you have a different model installed, pin it here.
# SWARM_LOCAL_MODEL=gemma3:4b
SWARM_LOCAL_TIMEOUT_MS=20000  # longer than hosted: a cold local model is slow on first call

# Anthropic. Remember: the key alone does nothing without SWARM_BACKEND=anthropic.
# ANTHROPIC_API_KEY=sk-ant-...
SWARM_MODEL=claude-haiku-4-5
SWARM_CALL_TIMEOUT_MS=10000

# Free-tier hosted, OpenAI-compatible chat completions. NOT READ YET: these land
# with the hosted backend. Listed here so the deploy config is written once.
# SWARM_HOSTED_BASE_URL=https://api.groq.com/openai/v1
# SWARM_HOSTED_MODEL=llama-3.3-70b-versatile
# SWARM_HOSTED_API_KEY=


# =============================================================================
# SERVER
# =============================================================================

PORT=4000
# Comma-separated origin allowlist. Dev also accepts private-LAN origins on port
# 3000 so phones can join by QR.
# CORS_ORIGINS=https://practice-arena-web.vercel.app
# Admin console key. Defaults to dev-operator in dev; REQUIRED in production.
# OPERATOR_KEY=
# Seed N house contestants at boot and after reset. An unseeded server has zero
# islanders and therefore zero conversations, which is why a stock run looks dead.
# DEV_SEED=14
# Override the walkable-mask JSON path for deployed layouts.
# ISLAND_MAP_PATH=/opt/love-aisland/assets/island-map.json
# Where phone numbers collected at join are appended.
CONTACTS_FILE=contacts.jsonl


# =============================================================================
# SMS (Twilio)
# =============================================================================
# All three must be set or every send falls to a [sms:noop] console line. That
# noop path is fully exercised locally and is the intended way to develop and
# test the alerting without an account.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=


# =============================================================================
# WEB (apps/web)
# =============================================================================
# Both are build-time inlined by Next, so changing either requires a redeploy,
# not just an env edit.

# Backend URL. Defaults to the current page hostname on port 4000.
# NEXT_PUBLIC_SOCKET_URL=wss://67-207-82-96.sslip.io
# Public or LAN web origin used in room QR links. Defaults to the page origin.
# NEXT_PUBLIC_APP_URL=
